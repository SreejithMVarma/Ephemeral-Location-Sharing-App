# ===== RENDER PRODUCTION ENVIRONMENT =====
# Set these in Render Dashboard > Environment

# API Base URL (Used by mobile clients for HTTP requests)
API_BASE_URL=https://ephemeral-location-sharing-app.onrender.com

# WebSocket URLs for each region (JSON format, use wss:// for production)
REGION_WS_URLS={"us-east":"wss://ephemeral-location-sharing-app.onrender.com/ws"}

# CORS Allowed Origins (JSON list)
CORS_ALLOWED_ORIGINS=["https://ephemeral-location-sharing-app.onrender.com"]

# Redis URL (Get from Render Dashboard > Database > Redis)
REDIS_URL=redis://default:PASSWORD@your-redis-host.c.composedb.com:11111

# Redis Configuration
REDIS_MAX_CONNECTIONS=100
REDIS_ENABLE_KEYSPACE_LISTENER=true

# Environment
APP_ENV=production

# Firebase Cloud Messaging
FCM_SENDER_ID=YOUR_FCM_SENDER_ID

# Deep link scheme
DEEP_LINK_SCHEME=radarapp

# Optional: Error tracking
SENTRY_DSN=
